# Go binary
/rabbithome
/rabbithome-*

# Node
web/node_modules/

# Local runtime data (config + uploaded backgrounds live in the OS config dir,
# but ignore any stray local data dir too)
/data/

# OS / editor noise
.DS_Store
*.swp

# NOTE: web/dist/ IS committed on purpose — it is embedded into the Go binary so
# that `go build` / `go install` works on a fresh clone without Node. Regenerate
# it with `make web`.
